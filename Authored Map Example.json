  "encounterTables": {
    "generic": [
      { "tag": "Quiet", "text": "The way is empty. Whatever happens here, you\u2019ll have to bring it yourself." },
      { "tag": "Discovery", "text": "You spot signs of recent passage \u2014 footprints, a cold fire, a dropped item." },
      { "tag": "Traveler", "text": "A figure approaches from a distance, alone." },
      { "tag": "Resource", "text": "Something useful presents itself, if you\u2019re willing to take the time." }
    ],
    "plains": [
      { "tag": "Traveler", "text": "A trade caravan crosses your path, dust rising behind it." },
      { "tag": "Sign", "text": "Crows circle something low in the grass ahead." }
    ],
    "forest": [
      { "tag": "Sign", "text": "The canopy thins where something large has passed through recently." },
      { "tag": "Hazard", "text": "The undergrowth conceals uneven, treacherous ground." }
    ],
    "hills": [
      { "tag": "Discovery", "text": "An old cairn marks this rise \u2014 someone wanted this place remembered." },
      { "tag": "Sign", "text": "The wind carries a sound that doesn\u2019t belong out here." }
    ],
    "mountains": [
      { "tag": "Hazard", "text": "Loose scree threatens the footing on the climb ahead." },
      { "tag": "Discovery", "text": "A sheltered overhang shows signs of recent use." }
    ],
    "water": [
      { "tag": "Sign", "text": "Something moves just beneath the surface." },
      { "tag": "Resource", "text": "The water here runs clear and cold \u2014 worth filling your stores." }
    ],
    "swamp": [
      { "tag": "Hazard", "text": "The ground gives more than it should underfoot." },
      { "tag": "Sign", "text": "A faint, sourceless light flickers between the reeds." }
    ],
    "ruins": [
      { "tag": "Discovery", "text": "Old stonework still bears marks worth puzzling over." },
      { "tag": "Hazard", "text": "Part of the structure looks ready to give way." }
    ],
    "settlement": [
      { "tag": "Traveler", "text": "Locals eye you with the particular curiosity reserved for outsiders." },
      { "tag": "Discovery", "text": "Word of something \u2014 a rumour, a job, a warning \u2014 reaches you quickly here." }
    ]
  },
